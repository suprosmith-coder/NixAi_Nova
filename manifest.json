      "src": "./icons/manifest/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Cyanix AI Desktop"
    }
  ],

  "shortcuts": [
    {
      "name": "New Chat",
      "short_name": "New Chat",
